
# Fix the MySQL grants at workers by applying a work around for a bug
# in the implementaton of the Relication/Ingest system:

ssh rubinqsv@sdfqserv001
cd /zfspool/management/qserv-slac/instance/slac6int
for host in $(cat config/workers); do
  echo $host;
  ssh $host "mysql -h127.0.0.1 -P3369 -uroot -p****** mysql -e 'GRANT ALL PRIVILEGES ON dp2_pilot.* TO qsmaster@127.0.0.1; FLUSH PRIVILEGES'";
done

